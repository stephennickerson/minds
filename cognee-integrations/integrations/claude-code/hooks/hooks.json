{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cognee-mcp-rs hook session-start",
            "timeout": 15,
            "statusMessage": "Initializing Cognee memory..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cognee-mcp-rs hook context-lookup",
            "timeout": 15,
            "statusMessage": "Searching Cognee memory..."
          },
          {
            "type": "command",
            "command": "cognee-mcp-rs hook store-user-prompt",
            "async": true
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Agent|Read|Write|Edit|Grep|Glob",
        "hooks": [
          {
            "type": "command",
            "command": "cognee-mcp-rs hook store-tool-use",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cognee-mcp-rs hook store-stop",
            "async": true
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cognee-mcp-rs hook pre-compact",
            "timeout": 15,
            "statusMessage": "Building memory anchor..."
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cognee-mcp-rs hook session-end"
          }
        ]
      }
    ]
  }
}
